# ==============================================================================
# Telegram AI Bot Configuration
# ==============================================================================
# Документация: https://github.com/mirash21/telegram-ai-bot-gigachat-yandex
# ==============================================================================

# ------------------------------------------------------------------------------
# GigaChat API Configuration (Обязательно)
# ------------------------------------------------------------------------------
# Вариант 1: Используйте готовый ключ авторизации из личного кабинета GigaChat
# Получите на: https://developers.sber.ru/
GIGACHAT_CREDENTIALS=your_authorization_key_here

# Вариант 2: Или укажите Client ID и Client Secret (они будут сконвертированы в Base64)
# Формат: echo -n "client_id:client_secret" | base64
# GIGACHAT_CLIENT_ID=your_client_id_here
# GIGACHAT_CLIENT_SECRET=your_client_secret_here

# Область доступа:
# - GIGACHAT_API_PERS  : Для физических лиц (бесплатно)
# - GIGACHAT_API_B2B   : Для ИП и юридических лиц (пакеты токенов)
# - GIGACHAT_API_CORP  : Для корпоративных клиентов (pay-as-you-go)
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# ------------------------------------------------------------------------------
# Yandex Cloud API Configuration (Опционально)
# ------------------------------------------------------------------------------
# Получите ключи в Yandex Cloud Console: https://console.cloud.yandex.ru/
# Необходимая роль сервисного аккаунта: ai.languageModels.user

# Folder ID каталога в Yandex Cloud
YANDEX_FOLDER_ID=your_folder_id_here

# API Key сервисного аккаунта
YANDEX_API_KEY=your_api_key_here

# ИЛИ используйте OAuth токен (альтернатива API ключу)
# YANDEX_OAUTH_TOKEN=your_oauth_token_here

# ------------------------------------------------------------------------------
# Telegram Bot Configuration
# ------------------------------------------------------------------------------
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ------------------------------------------------------------------------------
# Дополнительные настройки (Опционально)
# ------------------------------------------------------------------------------
# Прокси для Telegram (если заблокирован в регионе)
# Примеры:
# TELEGRAM_PROXY_URL=http://proxy.com:8080
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:9150

# ==============================================================================
